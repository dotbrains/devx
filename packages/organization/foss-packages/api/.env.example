# FOSS Package API Configuration

# =============================================================================
# API Server Configuration
# =============================================================================
FOSS_API_HOST=0.0.0.0
FOSS_API_PORT=8000
FOSS_API_RELOAD=true

# =============================================================================
# Authentication
# =============================================================================
# Comma-separated list of valid API tokens
# Generate tokens using: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable authentication (development only)
FOSS_API_TOKENS=

# Example with tokens (uncomment and replace with your tokens):
# FOSS_API_TOKENS=your-secret-token-1,your-secret-token-2,your-secret-token-3

# Require authentication for all endpoints (default: false)
# When false, only write operations require auth
FOSS_REQUIRE_AUTH=false

# =============================================================================
# CORS Configuration
# =============================================================================
FOSS_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# Security Scanning
# =============================================================================
# Trigger security scan automatically when a package is submitted
FOSS_SCAN_ON_SUBMIT=true
