# FOSS CLI Configuration
# Copy this file to .env and update with your values

# =============================================================================
# API Configuration
# =============================================================================

# FOSS Package API URL
# Default: http://localhost:8000
FOSS_API_URL=http://localhost:8000

# Production example:
# FOSS_API_URL=https://foss-api.your-domain.com

# =============================================================================
# Authentication
# =============================================================================

# API Authentication Token
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty if server doesn't require authentication
FOSS_API_TOKEN=

# Example (replace with your actual token):
# FOSS_API_TOKEN=x7jK9mN2pQ4rT8vW1yZ3bD5fH6gJ8kL0nM2oP4qR6sT8uV0wX2yZ4aB6cD8eF0g

# =============================================================================
# Output Options
# =============================================================================

# Enable verbose output (true/false)
# Default: false
FOSS_VERBOSE=false

# Output as JSON (true/false)
# Default: false
FOSS_JSON=false

# =============================================================================
# Usage Examples
# =============================================================================

# After setting these variables, you can use the CLI:
#
# List packages:
#   foss-cli list --type pypi
#
# Submit package (requires FOSS_API_TOKEN):
#   foss-cli submit requests 2.31.0 --type pypi
#
# Search packages:
#   foss-cli search flask
#
# Get package info:
#   foss-cli info requests 2.31.0

# =============================================================================
# Security Notes
# =============================================================================

# ⚠️  NEVER commit this file with actual tokens to version control!
# ⚠️  Add .env to .gitignore
# ⚠️  Keep your API tokens secret
# ⚠️  Rotate tokens regularly (every 90 days recommended)
