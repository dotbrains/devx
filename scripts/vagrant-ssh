#!/usr/bin/env bash
#
# vagrant-ssh - Smart wrapper for vagrant ssh
#
# Features:
#   - Automatically finds and switches to the correct Vagrant box directory
#   - Prevents Ctrl+C from terminating the session
#   - Supports --workdir flag to cd into a directory before executing commands
#
# Usage:
#   vagrant-ssh <box-name> [command]
#   vagrant-ssh <box-name> --workdir <dir> [command]
#
# Examples:
#   vagrant-ssh base-rocky10
#   vagrant-ssh standard-devenv "ls -la"
#   vagrant-ssh standard-devenv --workdir /workspace "git status"
#
set -euo pipefail

# Configuration
DEVX_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PACKAGES_DIR="${DEVX_ROOT}/packages"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Trap SIGINT (Ctrl+C) and ignore it
trap '' INT

# Function to print error and exit
error() {
    echo -e "${RED}Error: $1${NC}" >&2
    exit 1
}

# Function to print info
info() {
    echo -e "${GREEN}$1${NC}" >&2
}

# Function to find Vagrantfile directory for a given box name
find_vagrant_dir() {
    local box_name="$1"
    # Search for Vagrantfiles and check for matching box name or hostname
    while IFS= read -r vagrantfile; do
        local dir
        dir=$(dirname "$vagrantfile")
        if grep -q "vb.name = \"${box_name}\"" "$vagrantfile" 2>/dev/null || \
           grep -q "config.vm.hostname = \"${box_name}\"" "$vagrantfile" 2>/dev/null; then
            echo "$dir"
            return 0
        fi
    done < <(find "${PACKAGES_DIR}" -name "Vagrantfile" 2>/dev/null)
    return 1
}

# Function to show usage
usage() {
    cat << EOF
Usage: vagrant-ssh <box-name> [OPTIONS] [command]

Arguments:
  box-name              Name of the Vagrant VM (e.g., base-rocky10, standard-devenv)
  command               Optional command to execute in the VM

Options:
  --workdir <dir>       Change to this directory before executing command
  -h, --help            Show this help message

Examples:
  vagrant-ssh base-rocky10
  vagrant-ssh standard-devenv "ls -la"
  vagrant-ssh standard-devenv --workdir /workspace "git status"
EOF
    exit 0
}

# Parse arguments
if [ $# -eq 0 ]; then
    usage
fi

if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    usage
fi

BOX_NAME="$1"
shift

WORKDIR=""
COMMAND=""

# Parse options
while [ $# -gt 0 ]; do
    case "$1" in
        --workdir)
            if [ $# -lt 2 ]; then
                error "--workdir requires a directory argument"
            fi
            WORKDIR="$2"
            shift 2
            ;;
        *)
            # Remaining arguments form the command
            COMMAND="$*"
            break
            ;;
    esac
done

# Find the Vagrant directory
info "Looking for Vagrant VM: ${BOX_NAME}..."
VAGRANT_DIR=$(find_vagrant_dir "${BOX_NAME}" || true)

if [ -z "${VAGRANT_DIR}" ]; then
    error "Could not find a Vagrantfile for VM '${BOX_NAME}'.\nSearched under: ${PACKAGES_DIR}"
fi

info "Found VM at: ${VAGRANT_DIR}"

# Change to the Vagrant directory
cd "${VAGRANT_DIR}"

# Build the SSH command
if [ -n "${WORKDIR}" ] && [ -n "${COMMAND}" ]; then
    SSH_COMMAND="cd ${WORKDIR} && ${COMMAND}"
    vagrant ssh -c "${SSH_COMMAND}"
elif [ -n "${WORKDIR}" ] && [ -z "${COMMAND}" ]; then
    SSH_COMMAND="cd ${WORKDIR} && exec \$SHELL -l || exec bash -l"
    vagrant ssh -c "${SSH_COMMAND}"
elif [ -n "${COMMAND}" ]; then
    vagrant ssh -c "${COMMAND}"
else
    vagrant ssh
fi

# Reset the trap after vagrant ssh exits
trap - INT
